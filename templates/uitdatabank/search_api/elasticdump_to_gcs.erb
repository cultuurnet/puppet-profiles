#!/bin/bash

files=$@

bucket_dumplocation=<%= @bucket_dumplocation %>

for file in ${files}
do
    local_dumpfile=$(basename ${file})
    bucket_dumpfile=${local_dumpfile%%_v*}_full_$(date +%Y%m%d --date=yesterday).json

    echo "Copying local dumpfile ${file} to GCS bucket file ${bucket_dumplocation}/${bucket_dumpfile}"
    /usr/local/bin/sling run --src-stream file://${file} --src-options '{ "format": "jsonlines" }' --tgt-conn 'publiq-ingestion' --tgt-object ${bucket_dumplocation}/${bucket_dumpfile} --tgt-options '{ "format": "jsonlines" }'
done
