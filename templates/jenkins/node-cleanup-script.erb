#!/bin/bash

hostname=<%= @facts['networking']['fqdn'] %>
puppetserver_url=<%= scope.call_function('lookup', ['data::puppet::puppetserver::url']) %>
puppetdb_url=<%= scope.call_function('lookup', ['data::puppet::puppetdb::url']) %>

curl -s -o- -X DELETE -H 'Accept: pson' ${puppetserver_url}/puppet-ca/v1/certificate_status/$1 --cacert /var/lib/jenkins/.puppetlabs/puppet/ssl/certs/ca.pem --key /var/lib/jenkins/.puppetlabs/puppet/ssl/private_keys/${hostname}.pem --cert /var/lib/jenkins/.puppetlabs/puppet/ssl/certs/${hostname}.pem

curl -s -o- -X POST -H 'Accept: application/json' -H 'Content-Type: application/json' -d "{\"certname\": \"$1\"}" "${puppetdb_url}/pdb/cmd/v1?command=deactivate_node&version=3&certname=$1" --cacert /var/lib/jenkins/.puppetlabs/puppet/ssl/certs/ca.pem --key /var/lib/jenkins/.puppetlabs/puppet/ssl/private_keys/${hostname}.pem --cert /var/lib/jenkins/.puppetlabs/puppet/ssl/certs/${hostname}.pem
