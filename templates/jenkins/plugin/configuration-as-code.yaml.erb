---
unclassified:
  location:
    adminAddress: 'jenkins@publiq.be'
    url: '<%= @configuration['url'] %>'
jenkins:
<%- if @configuration['role_based_authorization'] -%>
  <%-
    pipelines       = [@configuration['pipelines']].flatten
    admin_pipelines = pipelines.select { |pipeline| [pipeline['authorization_groups']].flatten.include?('admin') }
    group_pipelines = pipelines.select { |pipeline| pipeline['authorization_groups'] } - admin_pipelines

    users             = [@configuration['users']].flatten
    admin_users       = users.select { |user| user['groups'] and user['groups'].include?('admin') }
    regular_users     = users.select { |user| not user['groups'] }
    custom_role_users = users.select { |user| not (regular_users.include?(user) or admin_users.include?(user)) }
    custom_groups     = custom_role_users.reduce([]) { |all, user| all << user['groups']; all.flatten.uniq }

    item_roles = custom_groups.reduce([]) { |all, group|
                   item_role_pipelines = group_pipelines.select { |pipeline| pipeline['authorization_groups'].include?(group) }
                   item_role_users     = custom_role_users.select { |user| user['groups'].include?(group) }

                   unless (item_role_pipelines.empty? or item_role_users.empty?); then
                     all << { 'name' => group, 'pipelines' => item_role_pipelines, 'users' => item_role_users }
                   end

                   all
                 }
  -%>
  projectNamingStrategy:
    roleBased:
      forceExistingJobs: true
  authorizationStrategy:
    roleBased:
      roles:
        global:
        - name: 'admin'
          permissions:
          - 'Overall/Administer'
          entries:
          - user: 'admin'
          <%- admin_users.each do |user| -%>
          - user: '<%= user['id'] %>'
          <%- end -%>
        - name: 'authenticated'
          permissions:
          - 'Overall/Read'
          entries:
          - group: 'authenticated'
        items:
        - name: 'users'
          pattern: '^(?!(<%= admin_pipelines.map { |pipeline| scope().call_function('slugify', [pipeline['name']]) }.join('|') %>)$)[\w-]*'
          permissions:
          - 'Job/Build'
          - 'Job/Cancel'
          - 'Job/Discover'
          - 'Job/Read'
          - 'Job/Workspace'
          - 'Run/Replay'
          entries:<%- if regular_users.empty? -%> []
          <%- else %>
          <%- regular_users.each do |user| -%>
          - user: '<%= user['id'] %>'
          <%- end -%>
          <%- end -%>
        <%- item_roles.each do |item_role| -%>
        - name: '<%= item_role['name'] %>'
          pattern: '^(<%= item_role['pipelines'].map { |pipeline| scope().call_function('slugify', [pipeline['name']]) }.join('|') %>)$'
          permissions:
          - 'Job/Build'
          - 'Job/Cancel'
          - 'Job/Discover'
          - 'Job/Read'
          - 'Job/Workspace'
          - 'Run/Replay'
          entries:
          <%- item_role['users'].each do |user| -%>
          - user: '<%= user['id'] %>'
          <%- end -%>
        <%- end -%>
<%- else -%>
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false
<%- end -%>
  numExecutors: 0
  slaveAgentPort: 0
  mode: NORMAL
  markupFormatter:
    rawHtml:
      disableSyntaxHighlighting: false
  securityRealm:
    local:
      allowsSignup: false
      users:
      - id: 'admin'
        name: 'Administrator'
        password: '<%= @configuration['admin_password'] %>'
        properties:
        - mailer:
            emailAddress: 'jenkins@publiq.be'
  globalNodeProperties:
  - envVars:
      env:
      - key: 'CI'
        value: 'true'
      - key: 'YARN_CACHE_FOLDER'
        value: '/var/lib/jenkins-swarm-client/.cache/yarn'
      - key: 'COMPOSER_CACHE_DIR'
        value: '/var/lib/jenkins-swarm-client/.cache/composer'
  viewsTabBar: "standard"
  views:
  - all:
      name: "all"
  <%- @configuration['views'].each do |view| -%>
  - list:
      name: '<%= view['name'] %>'
      includeRegex: '<%= view['regex'] %>'
      columns:
      - "status"
      - "weather"
      - "jobName"
      - "lastSuccess"
      - "lastFailure"
      - "lastDuration"
      - "buildButton"
      - "favoriteColumn"
  <%- end -%>
