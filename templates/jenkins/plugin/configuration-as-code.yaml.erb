---
unclassified:
  location:
    adminAddress: 'jenkins@publiq.be'
    url: '<%= @configuration['url'] %>'
jenkins:
<%- if @configuration['role_based_authorization'] -%>
<%-
users = [@configuration['users']].flatten.compact
pipelines = [@configuration['pipelines']].flatten.compact
user_groups = users.each_with_object({}) do |user, memo|
  groups = Array(user['groups']).compact
  memo[user['id']] = groups.empty? ? ['users'] : groups
end
admin_users = (['admin'] + user_groups.select { |_user_id, groups| groups.include?('admin') }.keys).compact.uniq
admin_job_names = pipelines.select { |pipeline| Array(pipeline['authorization_groups']).include?('admin') }.map { |pipeline| scope().call_function('slugify', [pipeline['name']]) }.compact.uniq
user_ids = user_groups.select { |_user_id, groups| groups.include?('users') }.keys.compact.uniq
user_role = if user_ids.empty?
              nil
            elsif admin_job_names.empty?
              {
                'group'    => 'users',
                'pattern'  => '.+',
                'user_ids' => user_ids,
              }
            else
              {
                'group'    => 'users',
                'pattern'  => "^(?!(#{admin_job_names.map { |job_name| Regexp.escape(job_name) }.join('|')})$).+",
                'user_ids' => user_ids,
              }
            end
custom_groups = pipelines.flat_map { |pipeline| Array(pipeline['authorization_groups']) }.compact.reject { |group| group == 'admin' or group == 'users' }.uniq.sort
custom_roles = custom_groups.map do |group|
  job_names = pipelines.select { |pipeline| Array(pipeline['authorization_groups']).include?(group) }.map { |pipeline| scope().call_function('slugify', [pipeline['name']]) }.compact.uniq
  user_ids = user_groups.select { |_user_id, groups| groups.include?(group) }.keys.compact.uniq

  next if job_names.empty? or user_ids.empty?

  {
    'group'     => group,
    'pattern'   => "^(#{job_names.map { |job_name| Regexp.escape(job_name) }.join('|')})$",
    'user_ids'  => user_ids,
  }
end.compact
item_roles = [user_role].compact + custom_roles
-%>
  projectNamingStrategy:
    roleBased:
      forceExistingJobs: true
  authorizationStrategy:
    roleBased:
      roles:
        global:
        - name: 'admin'
          permissions:
          - 'Overall/Administer'
          entries:
<%- admin_users.each do |user_id| -%>
          - user: '<%= user_id.to_s.gsub("'", "''") %>'
<%- end -%>
        - name: 'authenticated'
          permissions:
          - 'Overall/Read'
          entries:
          - group: 'authenticated'
<%- unless item_roles.empty? -%>
        items:
<%- item_roles.each do |role| -%>
        - name: '<%= role['group'].to_s.gsub("'", "''") %>'
          pattern: '<%= role['pattern'] %>'
          permissions:
          - 'Job/Build'
          - 'Job/Cancel'
          - 'Job/Discover'
          - 'Job/Read'
          - 'Job/Workspace'
          - 'Run/Replay'
          entries:
<%- role['user_ids'].each do |user_id| -%>
          - user: '<%= user_id.to_s.gsub("'", "''") %>'
<%- end -%>
<%- end -%>
<%- end -%>
<%- else -%>
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false
<%- end -%>
  numExecutors: 0
  slaveAgentPort: 0
  mode: NORMAL
  markupFormatter:
    rawHtml:
      disableSyntaxHighlighting: false
  securityRealm:
    local:
      allowsSignup: false
      users:
      - id: 'admin'
        name: 'Administrator'
        password: '<%= @configuration['admin_password'] %>'
        properties:
        - mailer:
            emailAddress: 'jenkins@publiq.be'
  globalNodeProperties:
  - envVars:
      env:
      - key: 'CI'
        value: 'true'
      - key: 'YARN_CACHE_FOLDER'
        value: '/var/lib/jenkins-swarm-client/.cache/yarn'
      - key: 'COMPOSER_CACHE_DIR'
        value: '/var/lib/jenkins-swarm-client/.cache/composer'
  viewsTabBar: "standard"
  views:
  - all:
      name: "all"
  <%- @configuration['views'].each do |view| -%>
  - list:
      name: '<%= view['name'] %>'
      includeRegex: '<%= view['regex'] %>'
      columns:
      - "status"
      - "weather"
      - "jobName"
      - "lastSuccess"
      - "lastFailure"
      - "lastDuration"
      - "buildButton"
      - "favoriteColumn"
  <%- end -%>
